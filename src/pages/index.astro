---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import Publications from '../components/Publications.astro';
import Skills from '../components/Skills.astro';
import Education from '../components/Education.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { load } from '../lib/data';

const site = load('site.yaml');
const hero = load('hero.yaml');
const about = load('about.yaml');
const experience = load('experience.yaml');
const publications = load('publications.yaml');
const skills = load('skills.yaml');
const education = load('education.yaml');
const contact = load('contact.yaml');
---
<BaseLayout title={site.title || 'Portfolio'} description={site.description || ''}>
  <Navbar />
  {(hero.name || hero.subtitle) && <Hero />}
  {(about.paragraphs || about.stats) && <About />}
  {experience.jobs?.length && <Experience />}
  {publications.papers?.length && <Publications />}
  {skills.categories?.length && <Skills />}
  {education.degrees?.length && <Education />}
  {(contact.heading || site.email) && <Contact />}
  <Footer />
</BaseLayout>
