---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blogs', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<'blogs'> };
const { Content } = await render(post);

const title = `${post.data.title} — Rishav Banerjee`;
const description = post.data.description || post.data.title;
---

<BaseLayout {title} {description}>
  <Navbar />

  <main class="pt-[64px]">
    <article class="py-20 md:py-28 px-5 md:px-6">
      <div class="max-w-[760px] mx-auto">
        <!-- Back link -->
        <a
          href="/blogs"
          class="inline-flex items-center gap-1.5 text-[14px] font-mono text-ink-tertiary hover:text-accent transition-colors no-underline mb-10"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          All posts
        </a>

        <!-- Post header -->
        <header class="mb-12">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <time
              datetime={post.data.date.toISOString().split('T')[0]}
              class="text-[13px] font-mono text-ink-tertiary"
            >
              {
                post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })
              }
            </time>
            {
              post.data.tags && post.data.tags.length > 0 && (
                <span class="flex items-center gap-1.5">
                  {post.data.tags.map((tag: string) => (
                    <span class="text-[12px] font-mono px-2 py-0.5 rounded-full bg-surface-sunken text-ink-tertiary border border-border">
                      {tag}
                    </span>
                  ))}
                </span>
              )
            }
          </div>
          <h1
            class="font-display text-[36px] md:text-[48px] font-bold text-ink tracking-[-0.01em] leading-[1.15]"
          >
            {post.data.title}
          </h1>
          {
            post.data.description && (
              <p class="mt-4 text-[18px] text-ink-secondary leading-[1.7]">
                {post.data.description}
              </p>
            )
          }
        </header>

        <!-- Divider -->
        <hr class="border-border mb-12" />

        <!-- Post content (prose) -->
        <div class="prose">
          <Content />
        </div>

        <!-- Post footer -->
        <hr class="border-border mt-16 mb-8" />
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <a
            href="/blogs"
            class="inline-flex items-center gap-1.5 text-[14px] font-mono text-ink-tertiary hover:text-accent transition-colors no-underline"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="19" y1="12" x2="5" y2="12"></line>
              <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to all posts
          </a>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Prose / blog content styling ── */
  .prose {
    font-family: var(--font-sans);
    color: var(--color-ink);
    line-height: 1.85;
    font-size: 17px;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    font-family: var(--font-display);
    color: var(--color-ink);
    font-weight: 700;
    line-height: 1.3;
    scroll-margin-top: 80px;
  }

  .prose :global(h2) {
    font-size: 28px;
    margin-top: 2.5em;
    margin-bottom: 0.6em;
    padding-bottom: 0.3em;
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(h3) {
    font-size: 22px;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }

  .prose :global(h4) {
    font-size: 19px;
    margin-top: 1.8em;
    margin-bottom: 0.4em;
  }

  .prose :global(p) {
    margin-bottom: 1.25em;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .prose :global(a:hover) {
    color: var(--color-accent-light);
  }

  .prose :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 0.5em 0 0.5em 1.25em;
    margin: 1.5em 0;
    color: var(--color-ink-secondary);
    font-style: italic;
  }

  .prose :global(blockquote p) {
    margin-bottom: 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.25em;
  }

  .prose :global(li) {
    margin-bottom: 0.35em;
  }

  .prose :global(li > ul),
  .prose :global(li > ol) {
    margin-top: 0.35em;
    margin-bottom: 0;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-surface-sunken);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--color-accent);
    border: 1px solid var(--color-border);
  }

  .prose :global(pre) {
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25em;
    margin: 1.5em 0;
    overflow-x: auto;
    font-size: 14px;
    line-height: 1.6;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-ink);
  }

  /* GitHub-flavored: tables */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    font-size: 15px;
  }

  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.6em 0.9em;
    text-align: left;
  }

  .prose :global(th) {
    background: var(--color-surface-sunken);
    font-weight: 600;
    color: var(--color-ink);
    font-family: var(--font-display);
  }

  .prose :global(tr:nth-child(even) td) {
    background: var(--color-surface-alt);
  }

  /* GitHub-flavored: task lists */
  .prose :global(input[type='checkbox']) {
    margin-right: 0.4em;
    accent-color: var(--color-accent);
  }

  /* Horizontal rule */
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2em 0;
  }

  /* Images */
  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5em 0;
  }

  /* Strikethrough (GFM) */
  .prose :global(del) {
    color: var(--color-ink-tertiary);
  }

  /* Footnotes */
  .prose :global(.footnotes) {
    font-size: 14px;
    color: var(--color-ink-secondary);
    border-top: 1px solid var(--color-border);
    margin-top: 2.5em;
    padding-top: 1.25em;
  }
</style>
