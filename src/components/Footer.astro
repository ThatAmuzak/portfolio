---
import { load, LI, liSrc } from '../lib/data';
import type { Site, Contact, FooterData } from '../lib/types';

const site = load<Site>('site.yaml');
const contact = load<Contact>('contact.yaml');
const footer: FooterData = contact.footer || {};
---

<footer class="py-8 px-6 bg-surface-sunken border-t border-border overflow-hidden">
  <div class="max-w-[1200px] mx-auto text-center text-[14px] text-ink-tertiary">
    <p class="m-0">
      &copy; {footer.copyrightPrefix}
      {
        footer.copyrightLinkLabel && (
          <a
            href={footer.copyrightLinkUrl}
            target="_blank"
            rel="noopener"
            class="text-ink-tertiary hover:text-accent transition-colors no-underline"
          >
            {footer.copyrightLinkLabel}
          </a>
        )
      }
      {footer.copyrightSuffix}
      {
        footer.iconsAttribution && (
          <>
            {' '}
            Icons by{' '}
            <a
              href={footer.iconsUrl || '#'}
              target="_blank"
              rel="noopener"
              class="text-ink-tertiary hover:text-accent transition-colors no-underline"
            >
              {footer.iconsAttribution}
            </a>
            .
          </>
        )
      }
    </p>
  </div>
</footer>
