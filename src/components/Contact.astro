---
import { load, LI, liSrc, obfuscateEmail } from '../lib/data';
import type { Site, SocialLink, Contact, ContactCTA } from '../lib/types';
import SectionHeader from './SectionHeader.astro';

const site = load<Site>('site.yaml');
const contact = load<Contact>('contact.yaml');
const social: SocialLink[] = site.social || [];
const ctaItems: ContactCTA[] = contact.cta || [];
const emailObfuscated = site.email ? obfuscateEmail(site.email) : '';
---

<section id="contact" class="py-20 md:py-28 px-5 md:px-6 bg-surface scroll-mt-16">
  <div class="max-w-[640px] mx-auto text-center">
    <SectionHeader
      label={contact.label}
      heading={contact.heading}
      headingMb="mb-6"
      headingSize="text-[28px] md:text-[44px]"
    />

    {
      contact.description && (
        <p class="reveal delay-1 text-[17px] md:text-[18px] text-ink-secondary leading-[1.75] mb-8 md:mb-10">
          {contact.description}
        </p>
      )
    }

    {
      site.email && (
        <div
          class="reveal delay-2 mb-8 md:mb-10 flex flex-wrap items-center justify-center gap-2 max-w-full"
          id="email-row"
        >
          <a
            href={`mailto:${emailObfuscated}`}
            class="inline-flex items-center gap-2 text-[clamp(11px,5vw,18px)] sm:text-[clamp(18px,4vw,26px)] md:text-[32px] font-mono font-bold text-accent hover:text-accent-light transition-colors min-w-0"
            id="email-link"
          >
            {contact.emailIcon && (
              <lord-icon
                src={liSrc(contact.emailIcon)}
                trigger="morph"
                colors={LI.dark}
                class="li-xl shrink-0"
                id="email-icon"
              />
            )}
            <span set:html={emailObfuscated} />
          </a>
          <button
            id="copy-email-btn"
            class="p-2 rounded-[6px] text-ink-tertiary hover:text-accent hover:bg-accent-wash transition-all duration-200 cursor-pointer bg-transparent border-none shrink-0"
            aria-label="Copy email to clipboard"
            title="Copy email"
            data-email={site.email}
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              id="copy-icon"
            >
              <>
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
              </>
            </svg>
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              id="check-icon"
              class="hidden text-accent"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </button>
        </div>
      )
    }

    {
      ctaItems.length > 0 && (
        <div class="reveal delay-2 mb-8 md:mb-10 flex flex-wrap items-center justify-center gap-3">
          {ctaItems.map((item: ContactCTA) => (
            <a
              href={item.href}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-ink-on-dark text-[15px] font-medium rounded-[6px] hover:bg-accent-light transition-all duration-200 no-underline"
            >
              {item.icon && (
                <lord-icon src={liSrc(item.icon)} trigger="morph" colors={LI.light} class="li-md" />
              )}
              {item.label}
            </a>
          ))}
        </div>
      )
    }

    {
      social.length > 0 && (
        <div class="reveal delay-3 flex flex-wrap items-center justify-center gap-5">
          {social.map((s: SocialLink) => (
            <a
              href={s.url}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 text-ink-tertiary hover:text-accent transition-colors no-underline text-[15px] font-mono"
              aria-label={s.label}
            >
              {s.icon && (
                <lord-icon src={liSrc(s.icon)} trigger="morph" colors={LI.dark} class="li-base" />
              )}
              {s.label}
            </a>
          ))}
        </div>
      )
    }

    <!-- Back to top -->
    <div class="reveal delay-3 mt-14">
      <button
        id="back-to-top"
        class="inline-flex items-center gap-2 px-5 py-2.5 text-[15px] font-medium text-ink-tertiary hover:text-accent transition-colors cursor-pointer bg-transparent border border-border rounded-full hover:border-accent"
        aria-label="Back to top"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"
          ></polyline></svg
        >
        Back to top
      </button>
    </div>
  </div>
</section>

<script>
  const copyBtn = document.getElementById('copy-email-btn');
  const copyIcon = document.getElementById('copy-icon');
  const checkIcon = document.getElementById('check-icon');
  let copyTimeout: ReturnType<typeof setTimeout> | null = null;

  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(copyBtn.dataset.email!);
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        copyBtn.classList.remove('copy-bounce');
        void copyBtn.offsetWidth;
        copyBtn.classList.add('copy-bounce');

        if (copyTimeout) clearTimeout(copyTimeout);
        copyTimeout = setTimeout(() => {
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
          copyTimeout = null;
        }, 2000);
      } catch {
        // clipboard write failed — silently ignore
      }
    });
  }

  // Back to top (snappy ease-out)
  const backBtn = document.getElementById('back-to-top');
  if (backBtn) {
    backBtn.addEventListener('click', () => {
      const startY = window.scrollY;
      const duration = 480;
      const startTime = performance.now();

      function step(now: number) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        window.scrollTo(0, startY * (1 - eased));
        if (progress < 1) requestAnimationFrame(step);
      }

      requestAnimationFrame(step);
    });
  }
</script>
