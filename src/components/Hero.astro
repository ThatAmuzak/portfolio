---
import { load, LI, liSrc } from '../lib/data';
import type { Hero } from '../lib/types';

const hero = load<Hero>('hero.yaml');
---

<section class="min-h-svh flex items-center px-5 md:px-6 pt-20 pb-8 md:pb-16 bg-surface">
  <div class="max-w-[780px] mx-auto md:mx-0 md:ml-[max(calc((100%-1100px)/2),2rem)]">
    {
      hero.subtitle && (
        <div class="reveal">
          <p class="text-[13px] md:text-[15px] font-mono text-accent tracking-[0.12em] uppercase mb-4 md:mb-5">
            {hero.subtitle}
          </p>
        </div>
      )
    }
    {
      hero.name && (
        <div class="reveal delay-1 flex items-center gap-4 mb-5 md:mb-7">
          {hero.icon && (
            <lord-icon
              src={liSrc(hero.icon)}
              trigger="morph"
              colors={LI.dark}
              class="li-hero hidden md:block"
            />
          )}
          <h1 class="font-display text-[42px] sm:text-[52px] md:text-[76px] lg:text-[90px] font-bold text-ink leading-[1.05] tracking-[-0.02em] m-0 break-words">
            {hero.name}
          </h1>
        </div>
      )
    }
    {
      hero.description && (
        <p class="reveal delay-2 text-[17px] md:text-[20px] text-ink-secondary leading-[1.7] mb-8 md:mb-10 max-w-[580px]">
          {hero.description}
        </p>
      )
    }
    <div class="reveal delay-3 flex flex-wrap items-center gap-4">
      {
        hero.cta?.resume && (
          <a
            href={hero.cta.resume.href}
            class="card-glow inline-flex items-center gap-3 px-7 py-4 bg-surface-raised text-ink-secondary text-[17px] sm:text-[18px] font-semibold rounded-[8px] no-underline border border-border hover:border-accent hover:text-accent"
          >
            <svg
              class="w-[22px] h-[22px] shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            {hero.cta.resume.label}
          </a>
        )
      }
      {
        hero.cta?.blogs && (
          <a
            href={hero.cta.blogs.href}
            class="card-glow inline-flex items-center gap-3 px-7 py-4 bg-surface-raised text-ink-secondary text-[17px] sm:text-[18px] font-semibold rounded-[8px] no-underline border border-border hover:border-accent hover:text-accent"
          >
            <lord-icon src={liSrc('hmpomorl')} trigger="morph" colors={LI.dark} class="li-lg" />
            {hero.cta.blogs.label}
          </a>
        )
      }
      {
        hero.cta?.connect && (
          <a
            href={hero.cta.connect.href}
            class="card-glow inline-flex items-center gap-3 px-7 py-4 bg-surface-raised text-ink-secondary text-[17px] sm:text-[18px] font-semibold rounded-[8px] no-underline border border-border hover:border-accent hover:text-accent"
          >
            {hero.cta.connect.icon && (
              <lord-icon
                src={liSrc(hero.cta.connect.icon)}
                trigger="morph"
                colors={LI.dark}
                class="li-lg"
              />
            )}
            {hero.cta.connect.label}
          </a>
        )
      }
    </div>
  </div>
</section>

<script>
  // Snappy ease-out scroll for hero CTAs that point to hash sections
  function scrollToTarget(target: HTMLElement) {
    const navbarH = 64;
    const targetY = target.getBoundingClientRect().top + window.scrollY - navbarH - 12;
    const startY = window.scrollY;
    const distance = targetY - startY;
    const duration = 480;
    const startTime = performance.now();

    function step(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      window.scrollTo(0, startY + distance * eased);
      if (progress < 1) requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  document.querySelectorAll('a[href^="#"]').forEach((link) => {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href')!);
      if (target) scrollToTarget(target as HTMLElement);
    });
  });
</script>
