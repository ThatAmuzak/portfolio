---
import { load } from '../lib/data';
import type { Experience, Job } from '../lib/types';
import SectionHeader from './SectionHeader.astro';

const experience = load<Experience>('experience.yaml');
const jobs: Job[] = experience.jobs || [];
---

<section id="experience" class="py-20 md:py-28 px-6 bg-surface scroll-mt-16">
  <div class="max-w-[960px] mx-auto">
    <SectionHeader label={experience.label} heading={experience.heading} headingMb="mb-12" />

    {
      jobs.length > 0 && (
        <div>
          {jobs.map((job: Job, i: number) => (
            <div class={`reveal ${i % 2 === 1 ? 'delay-1' : ''} flex`}>
              <div class="flex flex-col items-center shrink-0">
                <div class="w-3 h-3 rounded-full bg-accent ring-[4px] ring-surface mt-[10px]" />
                {i < jobs.length - 1 && <div class="w-[2px] bg-accent/20 flex-1 min-h-[14px]" />}
              </div>
              <div class={`pl-6 min-w-0 flex-1 ${i < jobs.length - 1 ? 'pb-14' : ''}`}>
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
                  <div>
                    {job.company && (
                      <h3 class="font-display text-[22px] font-bold text-ink m-0">
                        {job.url ? (
                          <a
                            href={job.url}
                            target="_blank"
                            rel="noopener"
                            class="text-ink no-underline hover:text-accent transition-colors"
                          >
                            {job.company}
                          </a>
                        ) : (
                          job.company
                        )}
                      </h3>
                    )}
                    {job.role && <p class="text-[16px] text-accent font-medium m-0">{job.role}</p>}
                  </div>
                  {job.dateRange && (
                    <span class="text-[14px] text-ink-tertiary font-mono">{job.dateRange}</span>
                  )}
                </div>
                {job.location && (
                  <p class="text-[14px] text-ink-tertiary mt-0 mb-3">{job.location}</p>
                )}

                {job.description && !job.details && (
                  <p class="text-[17px] text-ink-secondary leading-[1.7] mt-0 mb-4">
                    {job.description}
                  </p>
                )}
                {job.details && job.details.length > 0 && (
                  <ul class="list-none m-0 mb-4 space-y-2 pl-0">
                    {job.details.map((d: string) => (
                      <li class="text-[16px] text-ink-secondary leading-[1.7] flex items-start gap-2.5">
                        <span class="text-accent mt-[5px] shrink-0 select-none">▹</span>
                        <span>{d}</span>
                      </li>
                    ))}
                  </ul>
                )}

                {job.tech && job.tech.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {job.tech.map((t: string) => (
                      <span class="inline-block px-2.5 py-1 text-[13px] font-medium rounded bg-accent-wash text-accent font-mono">
                        {t}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      )
    }
  </div>
</section>
