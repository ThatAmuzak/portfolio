---
import { load, LI, liSrc } from '../lib/data';
import type { Site, NavItem } from '../lib/types';

const site = load<Site>('site.yaml');
const base = import.meta.env.BASE_URL;
const navItems: NavItem[] = site.nav || [];

// Hash links need the leading '/' so they work from sub-pages like /blogs
function navHref(item: NavItem) {
  return item.href.startsWith('#') ? `/${item.href}` : item.href;
}
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-[1200px] mx-auto px-6 h-[64px] flex items-center justify-between">
    <a
      href={base}
      class="font-display text-[18px] font-bold text-ink no-underline hover:text-accent transition-colors tracking-[-0.01em]"
    >
      {site.name || ''}
    </a>

    <!-- Blogs link — sits next to the brand name -->
    <a
      href="/blogs"
      class="hidden md:inline-flex items-center gap-1.5 text-[15px] text-ink-secondary hover:text-accent transition-colors no-underline font-medium ml-4"
    >
      <lord-icon src={liSrc('hmpomorl')} trigger="morph" colors={LI.dark} class="li-sm"></lord-icon>
      Blogs
    </a>

    <ul id="nav-links" class="hidden md:flex items-center gap-7 list-none m-0 p-0 ml-auto relative">
      {
        navItems.map((item: NavItem) => (
          <li>
            <a
              href={navHref(item)}
              data-section={item.href.replace('#', '')}
              class="nav-link inline-flex items-center gap-1.5 text-[15px] text-ink-secondary hover:text-accent transition-colors no-underline font-medium"
            >
              {item.icon && (
                <lord-icon src={liSrc(item.icon)} trigger="morph" colors={LI.dark} class="li-sm" />
              )}
              {item.label}
            </a>
          </li>
        ))
      }
      <span
        id="nav-underline"
        class="absolute bottom-0 left-0 h-[2px] bg-accent rounded-full pointer-events-none"
        style="width: 0; opacity: 0"></span>
      <li>
        <button
          id="theme-toggle"
          class="inline-flex items-center text-[15px] text-ink-secondary hover:text-accent transition-colors cursor-pointer bg-transparent border-none p-0 translate-y-[1.5px]"
          aria-label="Toggle dark mode"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="hidden dark:block"
            ><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line
              x1="12"
              y1="21"
              x2="12"
              y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line
              x1="18.36"
              y1="18.36"
              x2="19.78"
              y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line
              x1="21"
              y1="12"
              x2="23"
              y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line
              x1="18.36"
              y1="5.64"
              x2="19.78"
              y2="4.22"></line></svg
          >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="dark:hidden"
            ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg
          >
        </button>
      </li>
    </ul>

    <div class="md:hidden flex items-center gap-2">
      <button
        id="theme-toggle-mobile"
        class="p-2 text-ink-secondary hover:text-accent transition-all cursor-pointer bg-transparent border-none"
        aria-label="Toggle dark mode"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden dark:block"
          ><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line
            x1="12"
            y1="21"
            x2="12"
            y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line
            x1="18.36"
            y1="18.36"
            x2="19.78"
            y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line
            x1="21"
            y1="12"
            x2="23"
            y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line
            x1="18.36"
            y1="5.64"
            x2="19.78"
            y2="4.22"></line></svg
        >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="dark:hidden"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg
        >
      </button>
      {
        navItems.length > 0 && (
          <button
            id="mobile-menu-btn"
            class="flex flex-col gap-[6px] p-2 bg-transparent border-none cursor-pointer relative z-50"
            aria-label="Toggle menu"
            aria-expanded="false"
          >
            <span class="block w-6 h-[2px] bg-ink transition-all duration-300" id="bar1" />
            <span class="block w-6 h-[2px] bg-ink transition-all duration-300" id="bar2" />
            <span class="block w-6 h-[2px] bg-ink transition-all duration-300" id="bar3" />
          </button>
        )
      }
    </div>
  </div>

  {
    navItems.length > 0 && (
      <div
        id="mobile-menu"
        class="hidden md:hidden bg-surface-raised/95 backdrop-blur-lg border-b border-border"
      >
        <ul class="list-none m-0 p-0 py-4">
          <li>
            <a
              href="/blogs"
              class="flex items-center gap-2.5 px-6 py-3 text-[17px] text-ink-secondary hover:text-accent transition-colors no-underline"
            >
              <lord-icon src={liSrc('hmpomorl')} trigger="morph" colors={LI.dark} class="li-md" />
              Blogs
            </a>
          </li>
          {navItems.map((item: NavItem) => (
            <li>
              <a
                href={navHref(item)}
                class="flex items-center gap-2.5 px-6 py-3 text-[17px] text-ink-secondary hover:text-accent transition-colors no-underline"
              >
                {item.icon && (
                  <lord-icon
                    src={liSrc(item.icon)}
                    trigger="morph"
                    colors={LI.dark}
                    class="li-md"
                  />
                )}
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }
</nav>

<script>
  const navbar = document.getElementById('navbar');
  if (navbar) {
    const scrollClasses = [
      'bg-surface/90',
      'backdrop-blur-lg',
      'border-b',
      'border-border/50',
      'shadow-[0_1px_3px_rgba(0,0,0,0.05)]',
    ];
    function updateNavbar() {
      if (window.scrollY > 50) {
        navbar!.classList.add(...scrollClasses);
      } else {
        navbar!.classList.remove(...scrollClasses);
      }
    }
    updateNavbar();
    window.addEventListener('scroll', updateNavbar);
  }

  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
      if (!isOpen) {
        bar1?.classList.add('rotate-45', 'translate-y-[8px]');
        bar2?.classList.add('opacity-0');
        bar3?.classList.add('-rotate-45', '-translate-y-[8px]');
      } else {
        bar1?.classList.remove('rotate-45', 'translate-y-[8px]');
        bar2?.classList.remove('opacity-0');
        bar3?.classList.remove('-rotate-45', '-translate-y-[8px]');
      }
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        bar1?.classList.remove('rotate-45', 'translate-y-[8px]');
        bar2?.classList.remove('opacity-0');
        bar3?.classList.remove('-rotate-45', '-translate-y-[8px]');
      });
    });
  }

  // ── Snappy custom smooth scroll (ease-out cubic) ──
  // Only intercept clicks when we're on the homepage (sections exist here)
  const isHome = window.location.pathname === '/' || window.location.pathname === '';

  function scrollToTarget(target: HTMLElement) {
    const navbarH = 64;
    const targetY = target.getBoundingClientRect().top + window.scrollY - navbarH - 12;
    const startY = window.scrollY;
    const distance = targetY - startY;
    const duration = 480;
    const startTime = performance.now();

    function step(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      window.scrollTo(0, startY + distance * eased);
      if (progress < 1) requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  // Attach to all nav links that contain a hash
  document.querySelectorAll('.nav-link[data-section]').forEach((anchor) => {
    anchor.addEventListener('click', function (e) {
      const el = this as HTMLAnchorElement;
      const hash = '#' + el.dataset.section;
      if (isHome) {
        e.preventDefault();
        const target = document.querySelector(hash);
        if (target) scrollToTarget(target as HTMLElement);
      }
      // On non-home pages (e.g. /blogs), let the browser follow /#about naturally
    });
  });

  // Also handle mobile menu hash links
  document.querySelectorAll('#mobile-menu a[href*="#"]').forEach((anchor) => {
    anchor.addEventListener('click', function (e) {
      const el = this as HTMLAnchorElement;
      const href = el.getAttribute('href')!;
      const hash = href.includes('#') ? '#' + href.split('#')[1] : '';
      if (isHome && hash) {
        e.preventDefault();
        const target = document.querySelector(hash);
        if (target) scrollToTarget(target as HTMLElement);
      }
    });
  });

  // ── Active-section underline with lerp (homepage only) ──
  if (isHome) {
    const underline = document.getElementById('nav-underline');
    const navLinksContainer = document.getElementById('nav-links');
    if (underline && navLinksContainer) {
      const sectionLinks =
        navLinksContainer.querySelectorAll<HTMLAnchorElement>('.nav-link[data-section]');
      const sectionIds = Array.from(sectionLinks).map((l) => l.dataset.section!);
      const sections = sectionIds
        .map((id) => document.getElementById(id))
        .filter(Boolean) as HTMLElement[];

      if (sections.length > 0) {
        let activeId: string | null = null;
        const ratios = new Map<string, number>();

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              ratios.set(entry.target.id, entry.intersectionRatio);
            }
            // Pick the section with the highest visible ratio
            let best: string | null = null;
            let bestRatio = 0;
            for (const [id, ratio] of ratios) {
              if (ratio > bestRatio) {
                best = id;
                bestRatio = ratio;
              }
            }
            // Don't activate if we're above the first section
            if (bestRatio === 0) best = null;
            activeId = best;
          },
          { rootMargin: '-80px 0px -70% 0px', threshold: [0, 0.1, 0.3, 0.5, 0.7, 0.9, 1] },
        );

        for (const section of sections) observer.observe(section);

        // Lerp state
        let curLeft = 0;
        let curWidth = 0;
        let curOpacity = 0;

        function lerp() {
          const link = activeId
            ? (navLinksContainer!.querySelector(
                `.nav-link[data-section="${activeId}"]`,
              ) as HTMLElement | null)
            : null;

          let targetLeft = 0;
          let targetWidth = 0;
          let targetOpacity = 0;

          if (link) {
            const ulRect = navLinksContainer!.getBoundingClientRect();
            const linkRect = link.getBoundingClientRect();
            targetLeft = linkRect.left - ulRect.left;
            targetWidth = linkRect.width;
            targetOpacity = 1;
          }

          // Ease towards target (lower = slower/smoother)
          const speed = 0.18;
          curLeft += (targetLeft - curLeft) * speed;
          curWidth += (targetWidth - curWidth) * speed;
          curOpacity += (targetOpacity - curOpacity) * speed;

          underline.style.transform = `translateX(${curLeft}px)`;
          underline.style.width = `${curWidth}px`;
          underline.style.opacity = String(curOpacity);

          requestAnimationFrame(lerp);
        }

        requestAnimationFrame(lerp);
      }
    }
  } // end if (isHome)
</script>
