---
import { load, LI, liSrc } from '../lib/data';
import type { Skills, SkillCategory } from '../lib/types';
import SectionHeader from './SectionHeader.astro';

const skills = load<Skills>('skills.yaml');
const categories: SkillCategory[] = skills.categories || [];
---

<section id="skills" class="py-20 md:py-28 px-6 bg-surface scroll-mt-16">
  <div class="max-w-[960px] mx-auto">
    <SectionHeader label={skills.label} heading={skills.heading} headingMb="mb-12" />

    {
      categories.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {categories.map((cat: SkillCategory, i: number) => (
            <div
              class={`reveal ${i % 2 === 1 ? 'delay-1' : ''} card-glow bg-surface-raised rounded-[8px] p-6`}
            >
              <div class="flex items-center gap-3 mb-4">
                {cat.icon && (
                  <lord-icon src={liSrc(cat.icon)} trigger="morph" colors={LI.dark} class="li-xl" />
                )}
                {cat.name && (
                  <h3 class="font-mono text-[14px] font-medium text-accent m-0 uppercase tracking-[0.08em]">
                    {cat.name}
                  </h3>
                )}
              </div>
              {cat.items && cat.items.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {cat.items.map((item: string) => (
                    <span class="inline-block px-3 py-1.5 text-[14px] font-medium rounded-[4px] bg-accent-wash text-accent font-mono">
                      {item}
                    </span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      )
    }
  </div>
</section>
